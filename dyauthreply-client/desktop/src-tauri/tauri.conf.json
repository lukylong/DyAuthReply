{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "D助手",
  "version": "0.1.16",
  "identifier": "com.dyauthreply.client",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../client-ui",
    "devUrl": "http://localhost:5173/app/",
    "beforeBuildCommand": "npm run build --prefix ../client-ui",
    "frontendDist": "../../client-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "D助手",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzQjAzM0E5RDk0NDRGMDYKUldRR1QwVFpxVE93WS9wRFloTE1pbERjcHJIRXBXV1JOTDZnU3Q3STIrTUFIUmswbVRHaS8zdVEK",
      "endpoints": [
        "https://ghproxy.net/https://github.com/lukylong/DyAuthReply-dist/releases/latest/download/latest-ghproxynet.json",
        "https://gh-proxy.com/https://github.com/lukylong/DyAuthReply-dist/releases/latest/download/latest-ghproxycom.json",
        "https://ghfast.top/https://github.com/lukylong/DyAuthReply-dist/releases/latest/download/latest-ghfasttop.json",
        "https://github.com/lukylong/DyAuthReply-dist/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/launcher"
    ]
  }
}
