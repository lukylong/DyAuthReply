{
  "name": "dyauthreply-client",
  "private": true,
  "version": "0.1.0",
  "description": "DyAuthReply 桌面客户端（免 Docker）",
  "scripts": {
    "launcher": "python3 launcher/launcher.py",
    "ui:dev": "npm run dev --prefix client-ui",
    "ui:build": "npm run build --prefix client-ui",
    "desktop:dev": "npm run tauri dev --prefix desktop",
    "desktop:build": "npm run tauri build --prefix desktop",
    "dev": "echo '终端1: npm run launcher' && echo '终端2: npm run desktop:dev'"
  }
}
