# =============================================================================
# docker-compose 环境变量示例
# 复制为 .env 后按需修改；未设置的变量将使用 compose.yml 中的默认值。
#
#   cp .env.example .env
#
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=Reply_platform
POSTGRES_USER=Reply
POSTGRES_PASSWORD=wJYWYmVFKV2tzgMKr30D
POSTGRES_PORT=5432

# ---- Redis ----
# 为空则不开启密码；生产环境强烈建议设置
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Django Backend ----
BACKEND_PORT=8000
DJANGO_SECRET_KEY='zF3K7+pWn5/vYz7i9C+YD7QJn5K6V9L8M7N6M5L4K3J2H1G0F0E0D0C0B0A0908070605040302010'
JWT_ACCESS_SECRET_KEY='NxJ/4Zc9mG13iPRJC5BPXy3EXhuGpxMv9xK4NGLGIU1H5+GIAYfp/DSF4r0Y4th2pgIfvP8ia1tL6MaHVdSRnQ=='
JWT_REFRESH_SECRET_KEY='gZC5+Lnc6mH1DK1aFCjUxUPZzA3OcVuPr7+Hk/RgVqaCqx9PgdFUnNUz+HvWVSpKXX46qEaYxNg2o3HyvJDRXA=='  
# 设为 1 开启 uvicorn 热重载（开发环境）
UVICORN_RELOAD=1
# 首次启动是否自动加载 db_init.json（建议首次启动后改回 false）
AUTO_LOADDATA=true

# ---- Frontend (Vite) ----
WEB_PORT=5777

# ---- Douyin 模块（M2 里程碑起使用） ----
# 生成 Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DOUYIN_STORAGE_ENCRYPTION_KEY='MvshS8GcPoilCAnFpztspppQdhC0FPchRuPNsoAFebo='
# True=无头浏览器（Docker 容器内唯一可用）；False 只在本机直接运行 Python 时使用
# 注意：Docker 容器没有 X Server，强行 False 会让 Chromium 启动失败
DOUYIN_WORKER_HEADLESS=false
