{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DyAuthReply",
  "version": "0.1.7",
  "identifier": "com.dyauthreply.client",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../client-ui",
    "devUrl": "http://localhost:5173/app/",
    "beforeBuildCommand": "npm run build --prefix ../client-ui",
    "frontendDist": "../../client-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DyAuthReply",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/launcher"
    ]
  }
}
