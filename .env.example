# =============================================================================
# docker-compose 环境变量示例
# 复制为 .env 后按需修改；未设置的变量将使用 compose.yml 中的默认值。
#
#   cp .env.example .env
#
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=zq_platform
POSTGRES_USER=zq
POSTGRES_PASSWORD=zq_pass_change_me
POSTGRES_PORT=5432

# ---- Redis ----
# 为空则不开启密码；生产环境强烈建议设置
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Django Backend ----
BACKEND_PORT=8000
DJANGO_SECRET_KEY=please-change-me-to-a-long-random-string
JWT_ACCESS_SECRET_KEY=please-change-me-jwt-access
JWT_REFRESH_SECRET_KEY=please-change-me-jwt-refresh
# 设为 1 开启 uvicorn 热重载（开发环境）
UVICORN_RELOAD=1
# 首次启动是否自动加载 db_init.json（建议首次启动后改回 false）
AUTO_LOADDATA=false

# ---- Frontend (Vite) ----
WEB_PORT=5777

# ---- Douyin 模块（M2 里程碑起使用） ----
# 生成 Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DOUYIN_STORAGE_ENCRYPTION_KEY=
# True=无头浏览器；首次扫码登录需改为 False 并配合远程桌面/X 转发
DOUYIN_WORKER_HEADLESS=True
