# =============================================================================
# docker-compose 环境变量示例
# 复制为 .env 后按需修改；未设置的变量将使用 compose.yml 中的默认值。
#
#   cp .env.example .env
#
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=zq_platform
POSTGRES_USER=zq
POSTGRES_PASSWORD=zq_pass_change_me
POSTGRES_PORT=5432

# ---- Redis ----
# 为空则不开启密码；生产环境强烈建议设置
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Django Backend ----
BACKEND_PORT=8000
DJANGO_SECRET_KEY=please-change-me-to-a-long-random-string
JWT_ACCESS_SECRET_KEY=please-change-me-jwt-access
JWT_REFRESH_SECRET_KEY=please-change-me-jwt-refresh
# 设为 1 开启 uvicorn 热重载（开发环境）
UVICORN_RELOAD=1
# 首次启动是否自动加载 db_init.json（建议首次启动后改回 false）
AUTO_LOADDATA=false

# ---- Frontend (Nginx & Vite) ----
# WEB_PORT maps the host port to Nginx container port 80 (production) or Vite port (development)
WEB_PORT=80
WEB_SSL_PORT=443

# ---- Douyin 模块（M2 里程碑起使用） ----
# 生成 Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DOUYIN_STORAGE_ENCRYPTION_KEY=
# 纯协议（脱浏览器）默认值；登录方式：在后台「导入凭证」(cookie + web_protect + keys)
DOUYIN_TRANSPORT_BACKEND=http_protocol
DOUYIN_SIGN_BACKEND=js
DOUYIN_HTTP_PROTOCOL_SEND_TEXT=true
DOUYIN_HTTP_PROTOCOL_SEND_REPLY=true
DOUYIN_HTTP_PROTOCOL_SEND_STRICT=true
DOUYIN_HTTP_PROTOCOL_SCAN_INBOX=true
DOUYIN_HTTP_PROTOCOL_SCAN_STRICT=true

# ---- Douyin Worker 分片 / 租约（docker compose 默认 3 worker） ----
# 总分片数；必须与运行的 worker 实例数一致（douyin-worker-0/1/2 → COUNT=3）
DOUYIN_WORKER_SHARD_COUNT=3
# 多 worker 必须 true：Redis 租约防止重复托管同一账号
DOUYIN_WORKER_LEASE_ENABLED=true
# 租约 TTL（秒）；worker 崩溃后约 TTL 秒账号可被其它 worker 接管
DOUYIN_WORKER_LEASE_TTL=45
